# Copy to .env and fill in values. Never commit .env.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Active Record encryption — required for github_token at rest.
# Generate keys once: bin/rails db:encryption:init
# Copy the three values below into .env (development) and production secrets.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
# GOOD_JOB_USERNAME=ops
# GOOD_JOB_PASSWORD=
# APP_HOST=userstories.io
# SMTP settings if using a real mail server in development
