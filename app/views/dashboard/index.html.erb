<% content_for :title, "Inbox" %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-4xl px-6 py-10">
  <div class="mb-8">
    <h1 class="text-xl font-semibold text-stone-900 dark:text-stone-100">Triage inbox</h1>
    <p class="mt-0.5 text-sm text-stone-500">Review pending submissions from your collaborators.</p>
  </div>

  <%= render "shared/plan_usage", user: current_user %>

  <% if @pending_submissions.any? %>
    <ul class="card-list">
      <% @pending_submissions.each do |submission| %>
        <li>
          <%= link_to project_submission_path(submission.project, submission), class: "flex items-start justify-between gap-4 px-5 py-4 transition-colors duration-200 hover:bg-stone-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-brand-600 dark:hover:bg-stone-800/60" do %>
            <div class="min-w-0">
              <p class="truncate text-sm font-medium text-stone-900 dark:text-stone-100"><%= submission.title %></p>
              <p class="mt-1 text-xs text-stone-500">
                <span class="font-medium text-stone-600 dark:text-stone-400"><%= submission.project.name %></span>
                &middot; <%= submission.collaborator.name %>
                &middot; <%= submission.created_at.strftime("%b %-d") %>
              </p>
            </div>
            <%= render "shared/status_badge", status: "pending" %>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="mt-6 flex justify-center">
      <%= paginate @pending_submissions %>
    </div>
  <% else %>
    <div class="empty-state">
      <p class="text-sm font-semibold text-stone-900 dark:text-stone-100">Inbox zero</p>
      <p class="text-pretty mx-auto mt-2 max-w-sm text-sm text-stone-500">No pending submissions right now. When collaborators submit stories through your portal links, they will show up here.</p>
      <%= link_to "View projects", projects_path, class: "link-accent mt-5 inline-block text-sm" %>
    </div>
  <% end %>
</main>
