<% content_for :title, "Dashboard" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Triage Inbox</h1>

  <% if @pending_submissions.any? %>
    <ul class="divide-y divide-gray-200 border rounded-lg bg-white shadow-sm">
      <% @pending_submissions.each do |submission| %>
        <li class="px-4 py-4">
          <%= link_to project_submission_path(submission.project, submission), class: "block hover:bg-gray-50 -mx-4 px-4 py-1 rounded" do %>
            <div class="flex items-center justify-between">
              <span class="font-medium text-gray-900"><%= submission.title %></span>
              <span class="text-xs text-gray-400"><%= submission.created_at.strftime("%b %-d") %></span>
            </div>
            <div class="text-sm text-gray-500 mt-1">
              <%= submission.project.name %> &middot; <%= submission.collaborator.name %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg font-medium">Inbox zero</p>
      <p class="text-sm mt-1">No pending submissions to review.</p>
    </div>
  <% end %>
</div>
