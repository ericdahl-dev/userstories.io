<% if page.current? %>
  <span class="inline-flex min-w-9 items-center justify-center rounded-lg bg-stone-900 px-3 py-1.5 font-medium text-white dark:bg-stone-100 dark:text-stone-900" aria-current="page">
    <%= page %>
  </span>
<% else %>
  <%= link_to page, url, class: "inline-flex min-w-9 items-center justify-center rounded-lg px-3 py-1.5 text-stone-600 transition-colors hover:bg-stone-100 hover:text-stone-900 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-100", rel: page.next? ? "next" : page.prev? ? "prev" : nil, remote: remote %>
<% end %>
