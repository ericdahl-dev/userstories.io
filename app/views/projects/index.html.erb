<% content_for :title, "Projects" %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-4xl px-6 py-10">
  <div class="mb-8 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-xl font-semibold text-stone-900 dark:text-stone-100">Projects</h1>
      <p class="mt-0.5 text-sm text-stone-500">Each project has a shareable portal link for collaborators.</p>
    </div>
    <%= link_to "New project", new_project_path, class: "btn-primary shrink-0" %>
  </div>

  <% if @projects.any? %>
    <ul class="card-list">
      <% @projects.each do |project| %>
        <li class="flex items-center justify-between gap-4 px-5 py-4 transition-colors duration-200 hover:bg-stone-50 dark:hover:bg-stone-800/60">
          <div class="min-w-0">
            <%= link_to project.name, project_path(project), class: "text-sm font-medium text-stone-900 transition-colors duration-200 hover:text-brand-700 dark:text-stone-100 dark:hover:text-brand-400" %>
            <p class="mt-0.5 font-mono text-xs text-stone-500"><%= project.github_repo %></p>
          </div>
          <div class="flex shrink-0 items-center gap-3">
            <%= link_to "Submissions", project_submissions_path(project), class: "btn-ghost text-xs" %>
            <%= link_to "Edit", edit_project_path(project), class: "btn-ghost text-xs" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">
      <p class="text-sm font-semibold text-stone-900 dark:text-stone-100">No projects yet</p>
      <p class="mt-2 text-sm text-stone-500"><%= link_to "Create your first project", new_project_path, class: "link-accent" %> to connect a repo and share a portal link.</p>
    </div>
  <% end %>
</main>
