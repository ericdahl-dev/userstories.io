<% content_for :title, "Projects" %>

<%= render "shared/developer_nav" %>

<main class="max-w-4xl mx-auto px-6 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Projects</h1>
      <p class="text-sm text-gray-400 mt-0.5">Each project has a shareable portal link for collaborators.</p>
    </div>
    <%= link_to "New project", new_project_path,
          class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
  </div>

  <% if @projects.any? %>
    <ul class="divide-y divide-gray-100 border border-gray-200 rounded-xl overflow-hidden bg-white">
      <% @projects.each do |project| %>
        <li class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-gray-50 transition-colors">
          <div class="min-w-0">
            <%= link_to project.name, project_path(project), class: "text-sm font-medium text-gray-900 hover:text-indigo-600 transition-colors" %>
            <p class="text-xs text-gray-400 mt-0.5 font-mono"><%= project.github_repo %></p>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <%= link_to "Submissions", project_submissions_path(project), class: "text-xs text-gray-500 hover:text-gray-900 transition-colors" %>
            <%= link_to "Edit", edit_project_path(project), class: "text-xs text-gray-500 hover:text-gray-900 transition-colors" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="border border-gray-200 rounded-xl bg-white px-6 py-16 text-center">
      <p class="text-sm font-medium text-gray-900">No projects yet</p>
      <p class="text-sm text-gray-400 mt-1"><%= link_to "Create your first project", new_project_path, class: "text-indigo-600 hover:underline" %> to get started.</p>
    </div>
  <% end %>
</main>
