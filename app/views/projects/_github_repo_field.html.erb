<%= turbo_frame_tag "github_repos" do %>
  <div class="mb-1.5 flex items-center justify-between gap-3">
    <% if form %>
      <%= form.label :github_repo, "GitHub repository", class: "block text-sm font-medium text-stone-700 dark:text-stone-300" %>
    <% else %>
      <%= label_tag "project_github_repo", "GitHub repository", class: "block text-sm font-medium text-stone-700 dark:text-stone-300" %>
    <% end %>
    <%= link_to "Refresh list",
          github_repos_projects_path,
          class: "link-accent shrink-0 text-xs",
          data: { turbo_frame: "github_repos" } %>
  </div>

  <% if github_repos %>
    <% if form %>
      <%= form.select :github_repo,
            options_for_select(github_repos, project.github_repo),
            { include_blank: "Select a repository..." },
            class: "input-field font-mono" %>
    <% else %>
      <%= select_tag "project[github_repo]",
            options_for_select(github_repos, project.github_repo),
            include_blank: "Select a repository...",
            id: "project_github_repo",
            class: "input-field font-mono" %>
    <% end %>
  <% else %>
    <% if form %>
      <%= form.text_field :github_repo,
            placeholder: "owner/repo",
            class: "input-field font-mono" %>
    <% else %>
      <%= text_field_tag "project[github_repo]",
            project.github_repo,
            placeholder: "owner/repo",
            id: "project_github_repo",
            class: "input-field font-mono" %>
    <% end %>
    <p class="mt-1.5 text-xs text-amber-700 dark:text-amber-400">Could not load your repositories. Enter the repo identifier manually (e.g. owner/repo), or try refreshing the list.</p>
  <% end %>

  <p class="mt-1.5 text-xs text-stone-500">Issues will be created in this repository when you accept submissions.</p>
<% end %>
