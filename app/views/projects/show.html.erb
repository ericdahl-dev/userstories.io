<% content_for :title, @project.name %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-4xl px-6 py-10">
  <div class="mb-8">
    <%= link_to "← Projects", projects_path, class: "btn-ghost text-xs" %>
    <h1 class="mt-4 text-xl font-semibold text-stone-900 dark:text-stone-100"><%= @project.name %></h1>
    <p class="mt-0.5 font-mono text-sm text-stone-500"><%= @project.github_repo %></p>
  </div>

  <div class="space-y-4">
    <div class="card p-5">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-stone-500">Shareable portal link</p>
      <div class="panel-inset flex items-center gap-3 px-3 py-2">
        <code class="flex-1 truncate text-xs text-stone-700 dark:text-stone-300"><%= portal_url(share_token: @project.share_token) %></code>
        <%= button_to "Rotate",
              rotate_token_project_path(@project), method: :post,
              data: { confirm: "This will invalidate the current link immediately. Continue?" },
              class: "shrink-0 text-xs font-medium text-red-600 transition-colors duration-200 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300" %>
      </div>
      <p class="mt-2 text-xs text-stone-500">Rotating this link immediately revokes access for anyone using the old URL.</p>
    </div>

    <div class="flex flex-wrap items-center gap-3 pt-2">
      <%= link_to "View submissions", project_submissions_path(@project), class: "link-accent text-sm" %>
      <%= link_to "Edit project", edit_project_path(@project), class: "btn-ghost text-sm" %>
      <%= button_to "Delete",
            project_path(@project), method: :delete,
            data: { confirm: "Delete this project and all its submissions? This cannot be undone." },
            class: "text-sm text-red-600 transition-colors duration-200 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300" %>
    </div>
  </div>
</main>
