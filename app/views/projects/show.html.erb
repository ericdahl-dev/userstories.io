<% content_for :title, @project.name %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @project.name %></h1>
  <p class="text-sm text-gray-500 mb-6"><%= @project.github_repo %></p>

  <div class="bg-white border rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-2">Shareable link</h2>
    <div class="flex items-center gap-3">
      <code class="text-sm bg-gray-100 px-3 py-1 rounded flex-1 truncate"><%= portal_url(share_token: @project.share_token) %></code>
      <%= button_to "Rotate link", rotate_token_project_path(@project), method: :post,
            data: { confirm: "This will invalidate the current link immediately. Continue?" },
            class: "text-sm text-red-600 hover:underline" %>
    </div>
  </div>

  <div class="flex gap-3">
    <%= link_to "Edit", edit_project_path(@project), class: "text-sm text-gray-600 hover:underline" %>
    <%= link_to "View submissions", project_submissions_path(@project), class: "text-sm text-indigo-600 hover:underline" %>
    <%= button_to "Delete", project_path(@project), method: :delete,
          data: { confirm: "Delete this project and all its submissions?" },
          class: "text-sm text-red-600 hover:underline" %>
  </div>
</div>
