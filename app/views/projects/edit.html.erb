<% content_for :title, "Edit #{@project.name}" %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-lg px-6 py-10">
  <div class="mb-8">
    <%= link_to "← #{@project.name}", project_path(@project), class: "btn-ghost text-xs" %>
    <h1 class="mt-4 text-xl font-semibold text-stone-900 dark:text-stone-100">Edit project</h1>
  </div>

  <%= form_with model: @project, class: "space-y-5" do |f| %>
    <% if @project.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-800 dark:bg-red-950">
        <ul class="space-y-1 text-sm text-red-700 dark:text-red-300">
          <% @project.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Project name", class: "mb-1.5 block text-sm font-medium text-stone-700 dark:text-stone-300" %>
      <%= f.text_field :name, class: "input-field" %>
    </div>

    <div>
      <%= f.label :github_repo, "GitHub repository", class: "mb-1.5 block text-sm font-medium text-stone-700 dark:text-stone-300" %>
      <%= f.text_field :github_repo, placeholder: "owner/repo", class: "input-field font-mono" %>
    </div>

    <%= f.submit "Save changes", class: "btn-primary w-full cursor-pointer" %>
  <% end %>
</main>
