<% content_for :title, "Edit #{@project.name}" %>

<%= render "shared/developer_nav" %>

<main class="max-w-lg mx-auto px-6 py-10">
  <div class="mb-8">
    <%= link_to "← #{@project.name}", project_path(@project), class: "text-xs text-gray-400 hover:text-gray-700 transition-colors" %>
    <h1 class="text-xl font-semibold text-gray-900 mt-4">Edit project</h1>
  </div>

  <%= form_with model: @project, class: "space-y-5" do |f| %>
    <% if @project.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="text-sm text-red-700 space-y-1">
          <% @project.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Project name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_field :name,
            class: "w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <div>
      <%= f.label :github_repo, "GitHub repository", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_field :github_repo,
            placeholder: "owner/repo",
            class: "w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>

    <%= f.submit "Save changes",
          class: "w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg text-sm font-medium hover:bg-indigo-700 active:scale-[0.98] transition-all cursor-pointer" %>
  <% end %>
</main>
