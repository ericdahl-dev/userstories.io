<% content_for :title, "Sign in — #{@project.name}" %>

<div id="main-content" class="flex min-h-[100dvh] flex-col items-center justify-center px-4 surface-page">
  <div class="w-full max-w-md">
    <div class="mb-4 flex items-center justify-end">
      <%= render "shared/theme_toggle" %>
    </div>

    <div class="mb-6 flex justify-center">
      <%= render "shared/logo", href: root_path %>
    </div>

    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold tracking-tight text-stone-900 dark:text-stone-100"><%= @project.name %></h1>
    </div>

    <div class="card p-6 shadow-sm shadow-stone-900/5">
      <h2 class="mb-4 text-base font-semibold text-stone-900 dark:text-stone-100">Sign in with your email</h2>

      <%= form_with url: portal_sessions_path(share_token: @project.share_token), method: :post do |f| %>
        <div class="mb-4">
          <%= f.label :email, "Email address", class: "mb-1 block text-sm font-medium text-stone-700 dark:text-stone-300" %>
          <%= f.email_field :email, placeholder: "you@example.com", required: true, class: "input-field" %>
        </div>
        <%= f.submit "Send login link", class: "btn-primary w-full cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
