<% content_for :title, "Your submissions - #{@project.name}" %>
<% if @refresh_github_status %>
  <% content_for :head do %>
    <meta http-equiv="refresh" content="30">
  <% end %>
<% end %>

<div id="main-content" class="flex min-h-[100dvh] flex-col surface-page">
  <header class="border-b border-stone-200 bg-white px-6 py-4 dark:border-stone-800 dark:bg-stone-900">
    <div class="mx-auto flex max-w-2xl items-center justify-between">
      <div>
        <p class="text-sm font-semibold text-stone-900 dark:text-stone-100"><%= @project.name %></p>
        <div class="mt-0.5">
          <%= render "shared/logo",
                href: root_path,
                text_class: "text-xs text-stone-500",
                icon_class: "w-3.5 h-3.5" %>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <%= render "shared/theme_toggle" %>
        <%= render "portal/sign_out_button", project: @project %>
        <%= link_to "New submission", new_portal_submission_path(share_token: @project.share_token), class: "btn-primary-sm" %>
      </div>
    </div>
  </header>

  <main class="flex-1 px-6 py-10">
    <div class="mx-auto max-w-2xl">
      <% if notice.present? %>
        <div class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-800 dark:bg-emerald-950 dark:text-emerald-200" role="status">
          <%= notice %>
        </div>
      <% end %>

      <div class="mb-6">
        <h1 class="text-xl font-semibold text-stone-900 dark:text-stone-100">Your submissions</h1>
        <p class="mt-0.5 text-sm text-stone-500">Track the stories you've shared with the team.</p>
        <p class="mt-1 text-xs text-stone-400 dark:text-stone-500">
          Submitting as <strong class="text-stone-600 dark:text-stone-300"><%= current_collaborator.name %></strong>
          — <%= link_to "change", edit_portal_profile_path(share_token: @project.share_token), class: "link-accent" %>
          <span class="ml-1 text-stone-400">(public · appears on GitHub issues)</span>
        </p>
      </div>

      <% if @submissions.any? %>
        <ul class="card-list">
          <% @submissions.each do |submission| %>
            <li class="flex items-start justify-between gap-4 px-5 py-4">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-stone-900 dark:text-stone-100">
                  <%= submission.refined_title.presence || submission.title %>
                </p>
                <p class="mt-1 text-xs text-stone-500"><%= submission.created_at.strftime("%b %-d, %Y") %></p>
                <% if submission.refinement_chat_open? && submission.refinement_messages.any? %>
                  <p class="mt-2 text-xs">
                    <%= link_to "Continue refining",
                          portal_submission_refine_path(share_token: @project.share_token, id: submission),
                          class: "link-accent" %>
                  </p>
                <% end %>
                <% if submission.github_issue_number.present? && submission.github_issue_url.present? %>
                  <%= render "portal/submissions/github_issue_status", submission: submission %>
                <% end %>
              </div>
              <%= render "shared/status_badge", status: submission.status %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-state">
          <p class="text-sm font-semibold text-stone-900 dark:text-stone-100">No submissions yet</p>
          <p class="mt-2 text-sm text-stone-500">
            <%= link_to "Submit your first story", new_portal_submission_path(share_token: @project.share_token), class: "link-accent" %>
          </p>
        </div>
      <% end %>
    </div>
  </main>
</div>
