<% content_for :title, "My submissions — #{@project.name}" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Your submissions</h1>
    <%= link_to "New submission", new_portal_submission_path(share_token: @project.share_token),
          class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700" %>
  </div>

  <% if notice %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 text-sm text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <% if @submissions.any? %>
    <ul class="divide-y divide-gray-200 border rounded-lg bg-white shadow-sm">
      <% @submissions.each do |submission| %>
        <li class="px-4 py-4 flex items-center justify-between">
          <div>
            <p class="font-medium text-gray-900"><%= submission.title %></p>
            <p class="text-sm text-gray-500 mt-0.5"><%= submission.created_at.strftime("%b %-d, %Y") %></p>
          </div>
          <span class="text-xs font-medium px-2 py-1 rounded-full
            <%= submission.status == 'shipped' ? 'bg-green-100 text-green-800' :
                submission.status == 'accepted' ? 'bg-blue-100 text-blue-800' :
                'bg-gray-100 text-gray-600' %>">
            <%= submission.status %>
          </span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg font-medium">No submissions yet</p>
      <p class="text-sm mt-1"><%= link_to "Submit your first story", new_portal_submission_path(share_token: @project.share_token), class: "text-indigo-600 hover:underline" %>.</p>
    </div>
  <% end %>
</div>
