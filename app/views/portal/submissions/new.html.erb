<% content_for :title, "New submission — #{@project.name}" %>

<div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4">
  <div class="max-w-lg w-full">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900"><%= @project.name %></h1>
      <p class="text-gray-500 mt-2">Share your idea with the developer.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Submit a user story</h2>

      <%= form_with model: @submission, url: portal_submissions_path(share_token: @project.share_token), class: "space-y-4" do |f| %>
        <% if @submission.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded p-3">
            <ul class="text-sm text-red-700 list-disc pl-4">
              <% @submission.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :title, placeholder: "As a user, I want…",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :body, "Details", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :body, rows: 5, placeholder: "Describe what you'd like to happen and why…",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>

        <%= f.submit "Submit story", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-lg text-sm font-medium hover:bg-indigo-700" %>
      <% end %>
    </div>
  </div>
</div>
