<% content_for :title, @project.name %>

<div id="main-content" class="flex min-h-[100dvh] flex-col surface-page">
  <header class="border-b border-stone-200 bg-white px-6 py-4 dark:border-stone-800 dark:bg-stone-900">
    <div class="mx-auto flex max-w-lg items-center justify-between">
      <div>
        <p class="text-sm font-semibold text-stone-900 dark:text-stone-100"><%= @project.name %></p>
        <div class="mt-0.5">
          <%= render "shared/logo",
                href: root_path,
                text_class: "text-xs text-stone-500",
                icon_class: "w-3.5 h-3.5" %>
        </div>
      </div>
      <%= render "shared/theme_toggle" %>
    </div>
  </header>

  <main class="flex flex-1 items-center justify-center px-6 py-10">
    <div class="w-full max-w-sm">
      <% if notice.present? %>
        <div class="mb-5 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-800 dark:bg-emerald-950 dark:text-emerald-200" role="status">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-5 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-950 dark:text-red-300" role="alert">
          <%= alert %>
        </div>
      <% end %>

      <div class="card p-6">
        <h2 class="mb-1 text-base font-semibold text-stone-900 dark:text-stone-100">Sign in to continue</h2>
        <p class="mb-5 text-sm text-stone-500">Enter your email and we'll send you a one-click login link.</p>

        <%= form_with url: portal_sessions_path(share_token: @project.share_token), method: :post do |f| %>
          <div class="mb-4">
            <%= f.label :email, "Email address", class: "mb-1.5 block text-xs font-medium text-stone-600 dark:text-stone-400" %>
            <%= f.email_field :email,
                  placeholder: "you@example.com",
                  required: true,
                  autofocus: true,
                  class: "input-field" %>
          </div>
          <%= f.submit "Send login link", class: "btn-primary w-full cursor-pointer" %>
        <% end %>
      </div>

      <p class="mt-5 text-center text-xs text-stone-500">
        No account needed. Check your email after submitting.
      </p>
    </div>
  </main>
</div>
