<% content_for :title, @project.name %>

<div class="min-h-[100dvh] bg-gray-50 flex flex-col">
  <header class="px-6 py-4 border-b border-gray-200 bg-white">
    <div class="max-w-lg mx-auto">
      <p class="text-sm font-semibold text-gray-900"><%= @project.name %></p>
      <p class="text-xs text-gray-400 mt-0.5">via userstories.io</p>
    </div>
  </header>

  <main class="flex-1 flex items-center justify-center px-6 py-10">
    <div class="w-full max-w-sm">
      <% if notice.present? %>
        <div class="mb-5 bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-800">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-5 bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700">
          <%= alert %>
        </div>
      <% end %>

      <div class="bg-white border border-gray-200 rounded-xl p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-1">Sign in to continue</h2>
        <p class="text-sm text-gray-400 mb-5">Enter your email and we'll send you a one-click login link.</p>

        <%= form_with url: portal_sessions_path(share_token: @project.share_token), method: :post do |f| %>
          <div class="mb-4">
            <%= f.label :email, "Email address", class: "block text-xs font-medium text-gray-600 mb-1.5" %>
            <%= f.email_field :email,
                  placeholder: "you@example.com",
                  required: true,
                  autofocus: true,
                  class: "w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          </div>
          <%= f.submit "Send login link",
                class: "w-full bg-indigo-600 text-white py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 active:scale-[0.98] transition-all cursor-pointer" %>
        <% end %>
      </div>

      <p class="text-xs text-center text-gray-400 mt-5">
        No account needed. Check your email after submitting.
      </p>
    </div>
  </main>
</div>
