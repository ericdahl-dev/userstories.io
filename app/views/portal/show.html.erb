<% content_for :title, @project.name %>

<div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900"><%= @project.name %></h1>
      <p class="text-gray-500 mt-2">Submit a user story or sign in to track your submissions.</p>
    </div>

    <% if notice %>
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 text-sm text-green-800">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-800">
        <%= alert %>
      </div>
    <% end %>

    <div class="bg-white rounded-xl shadow-sm border p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Sign in with your email</h2>

      <%= form_with url: portal_sessions_path(share_token: @project.share_token), method: :post do |f| %>
        <div class="mb-4">
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, placeholder: "you@example.com", required: true,
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
        </div>
        <%= f.submit "Send login link", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-lg text-sm font-medium hover:bg-indigo-700" %>
      <% end %>
    </div>
  </div>
</div>
