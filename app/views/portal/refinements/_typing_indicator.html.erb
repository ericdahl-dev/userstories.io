<%= tag.div id: "refinement_typing_indicator", class: "flex justify-start", role: "status", aria: { live: "polite" } do %>
  <div class="max-w-[85%] rounded-2xl rounded-bl-md border border-stone-200 bg-white px-4 py-3 text-sm text-stone-500 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-400">
    <span class="inline-flex items-center gap-2">
      <span class="flex gap-1" aria-hidden="true">
        <span class="size-1.5 animate-bounce rounded-full bg-stone-400 [animation-delay:-0.2s] dark:bg-stone-500"></span>
        <span class="size-1.5 animate-bounce rounded-full bg-stone-400 [animation-delay:-0.1s] dark:bg-stone-500"></span>
        <span class="size-1.5 animate-bounce rounded-full bg-stone-400 dark:bg-stone-500"></span>
      </span>
      Thinking…
    </span>
  </div>
<% end %>
