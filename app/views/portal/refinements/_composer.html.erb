<%# locals: (submission:, project:) %>
<% composer_disabled = submission.refinement_locked? || submission.refinement_at_cap? || submission.refinement_processing? %>

<% unless submission.refinement_locked? %>
  <div data-controller="refinement-finalize" class="flex flex-col gap-4">
    <p class="text-sm text-stone-600 dark:text-stone-400">
      The assistant refines your story against the codebase. Reply below to clarify — you have
      <span class="font-medium text-stone-800 dark:text-stone-200"><%= refinement_reply_counter(submission).downcase %></span>.
      When you're ready, submit for developer review.
    </p>

    <%= form_with url: portal_submission_refine_messages_path(share_token: project.share_token, id: submission),
                  scope: :refinement_message,
                  class: "flex items-end gap-3",
                  data: { controller: "refinement-form", action: "turbo:submit-start->refinement-form#submit" } do |f| %>
      <%= f.text_area :body,
            rows: 3,
            disabled: composer_disabled,
            placeholder: composer_disabled ? "Refinement chat is closed." : "Type a reply…",
            class: "min-h-[5.5rem] flex-1 resize-none rounded-lg border border-stone-200 bg-white px-3 py-2 text-sm text-stone-900 placeholder:text-stone-400 focus:border-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-200 disabled:cursor-not-allowed disabled:bg-stone-100 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-100 dark:placeholder:text-stone-500 dark:disabled:bg-stone-800",
            data: { refinement_form_target: "body" } %>
      <%= f.submit "Send",
            disabled: composer_disabled,
            class: "btn-secondary shrink-0 disabled:cursor-not-allowed disabled:opacity-50",
            data: { refinement_form_target: "submit" } %>
    <% end %>

    <%= button_to "Submit for review",
          portal_submission_refine_finalize_path(share_token: project.share_token, id: submission),
          method: :post,
          form: { class: "hidden", data: { refinement_finalize_target: "form" } },
          class: "hidden" %>

    <button type="button"
            class="btn-primary w-full"
            data-action="refinement-finalize#open">
      Submit for review
    </button>

    <dialog data-refinement-finalize-target="dialog"
            data-action="click->refinement-finalize#backdropClose"
            class="w-[calc(100%-2rem)] max-w-md rounded-xl border border-stone-200 bg-white p-6 text-stone-900 shadow-xl backdrop:bg-stone-900/50 open:flex open:flex-col open:gap-4 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-100">
      <div>
        <h2 class="text-base font-semibold text-stone-900 dark:text-stone-100">Submit for review?</h2>
        <p class="mt-2 text-sm text-stone-600 dark:text-stone-400">
          Your story will go to the developer for triage. You won't be able to send more chat messages after submitting.
        </p>
      </div>
      <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
        <button type="button"
                class="btn-secondary w-full sm:w-auto"
                data-action="refinement-finalize#close">
          Cancel
        </button>
        <button type="button"
                class="btn-primary w-full sm:w-auto"
                data-action="refinement-finalize#confirm">
          Submit for review
        </button>
      </div>
    </dialog>
  </div>
<% end %>
