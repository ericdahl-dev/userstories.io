<% content_for :title, @submission.title %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-2xl px-6 py-10">
  <div class="mb-8">
    <%= link_to "← Submissions", project_submissions_path(@project), class: "btn-ghost text-xs" %>
  </div>

  <div class="card mb-5 p-6">
    <div class="mb-5 flex items-start justify-between gap-4">
      <h1 class="text-base font-semibold leading-snug text-stone-900 dark:text-stone-100"><%= @submission.title %></h1>
      <%= render "shared/status_badge", status: @submission.status %>
    </div>

    <p class="whitespace-pre-wrap text-sm leading-relaxed text-stone-700 dark:text-stone-300"><%= @submission.body %></p>

    <div class="mt-6 flex items-center gap-4 border-t border-stone-100 pt-5 text-xs text-stone-500 dark:border-stone-800">
      <span class="font-medium text-stone-600 dark:text-stone-400"><%= @submission.collaborator.name %></span>
      <span><%= @submission.collaborator.email %></span>
      <span><%= @submission.created_at.strftime("%b %-d, %Y") %></span>
    </div>

    <% if @submission.github_issue_url.present? %>
      <div class="mt-4 border-t border-stone-100 pt-4 dark:border-stone-800">
        <%= link_to "GitHub issue ##{@submission.github_issue_number}", @submission.github_issue_url,
              target: "_blank", rel: "noopener noreferrer",
              class: "link-accent text-xs" %>
      </div>
    <% end %>
  </div>

  <% if @submission.status == "pending" %>
    <div class="flex items-center gap-3">
      <%= button_to "Accept", accept_project_submission_path(@project, @submission), method: :post, class: "btn-primary" %>
      <%= button_to "Dismiss", dismiss_project_submission_path(@project, @submission), method: :post,
            class: "btn-secondary text-red-600 hover:border-red-200 hover:text-red-700 dark:text-red-400 dark:hover:border-red-800 dark:hover:text-red-300" %>
    </div>
  <% end %>

  <% if @submission.status == "accepted" %>
    <div class="flex items-center gap-3">
      <%= button_to "Mark as shipped", ship_project_submission_path(@project, @submission), method: :post,
            class: "inline-flex items-center justify-center rounded-lg bg-emerald-600 px-5 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-emerald-700 active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-600 focus-visible:ring-offset-2" %>
    </div>
  <% end %>
</main>
