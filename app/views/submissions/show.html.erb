<% content_for :title, @submission.title %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Submissions", project_submissions_path(@project), class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <% if notice %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 text-sm text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <% if alert %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-800">
      <%= alert %>
    </div>
  <% end %>

  <div class="bg-white border rounded-xl shadow-sm p-6 mb-6">
    <div class="flex items-start justify-between mb-4">
      <h1 class="text-xl font-bold text-gray-900"><%= @submission.title %></h1>
      <span class="text-xs font-medium px-2 py-1 rounded-full ml-4
        <%= @submission.status == 'accepted' ? 'bg-blue-100 text-blue-800' :
            @submission.status == 'shipped'  ? 'bg-green-100 text-green-800' :
            @submission.status == 'dismissed' ? 'bg-gray-100 text-gray-500' :
            'bg-yellow-100 text-yellow-800' %>">
        <%= @submission.status %>
      </span>
    </div>

    <p class="text-gray-700 whitespace-pre-wrap"><%= @submission.body %></p>

    <div class="mt-6 pt-4 border-t border-gray-100 text-sm text-gray-500 flex items-center gap-4">
      <span><%= @submission.collaborator.name %></span>
      <span><%= @submission.collaborator.email %></span>
      <span><%= @submission.created_at.strftime("%b %-d, %Y") %></span>
    </div>

    <% if @submission.github_issue_url.present? %>
      <div class="mt-4">
        <%= link_to "View GitHub issue ##{@submission.github_issue_number}", @submission.github_issue_url,
              target: "_blank", rel: "noopener noreferrer",
              class: "text-sm text-indigo-600 hover:underline" %>
      </div>
    <% end %>
  </div>

  <% if @submission.status == "pending" %>
    <div class="flex gap-3">
      <%= button_to "Accept", accept_project_submission_path(@project, @submission), method: :post,
            class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700" %>
      <%= button_to "Dismiss", dismiss_project_submission_path(@project, @submission), method: :post,
            class: "text-red-600 text-sm font-medium hover:underline px-4 py-2 border border-red-200 rounded-lg hover:bg-red-50" %>
    </div>
  <% end %>
</div>
