<% content_for :title, @submission.title %>

<%= render "shared/developer_nav" %>

<main class="max-w-2xl mx-auto px-6 py-10">
  <div class="mb-8">
    <%= link_to "← Submissions", project_submissions_path(@project), class: "text-xs text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
  </div>

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-6 mb-5">
    <div class="flex items-start justify-between gap-4 mb-5">
      <h1 class="text-base font-semibold text-gray-900 dark:text-gray-100 leading-snug"><%= @submission.title %></h1>
      <span class="shrink-0 text-[10px] font-medium px-2 py-0.5 rounded-full border
        <%= @submission.status == 'accepted'  ? 'bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800' :
            @submission.status == 'shipped'   ? 'bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800' :
            @submission.status == 'dismissed' ? 'bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-700' :
            'bg-amber-50 dark:bg-amber-950 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800' %>">
        <%= @submission.status %>
      </span>
    </div>

    <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap"><%= @submission.body %></p>

    <div class="mt-6 pt-5 border-t border-gray-100 dark:border-gray-800 flex items-center gap-4 text-xs text-gray-400 dark:text-gray-500">
      <span class="font-medium text-gray-500 dark:text-gray-400"><%= @submission.collaborator.name %></span>
      <span><%= @submission.collaborator.email %></span>
      <span><%= @submission.created_at.strftime("%b %-d, %Y") %></span>
    </div>

    <% if @submission.github_issue_url.present? %>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
        <%= link_to "GitHub issue ##{@submission.github_issue_number}", @submission.github_issue_url,
              target: "_blank", rel: "noopener noreferrer",
              class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" %>
      </div>
    <% end %>
  </div>

  <% if @submission.status == "pending" %>
    <div class="flex items-center gap-3">
      <%= button_to "Accept", accept_project_submission_path(@project, @submission), method: :post,
            class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 active:scale-[0.98] transition-all" %>
      <%= button_to "Dismiss", dismiss_project_submission_path(@project, @submission), method: :post,
            class: "px-5 py-2.5 border border-gray-200 dark:border-gray-700 text-sm text-gray-500 dark:text-gray-400 font-medium rounded-lg hover:border-red-200 dark:hover:border-red-800 hover:text-red-600 dark:hover:text-red-400 active:scale-[0.98] transition-all" %>
    </div>
  <% end %>

  <% if @submission.status == "accepted" %>
    <div class="flex items-center gap-3">
      <%= button_to "Mark as shipped", ship_project_submission_path(@project, @submission), method: :post,
            class: "px-5 py-2.5 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 active:scale-[0.98] transition-all" %>
    </div>
  <% end %>
</main>
