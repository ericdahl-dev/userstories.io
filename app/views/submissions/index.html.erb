<% content_for :title, "Submissions — #{@project.name}" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← #{@project.name}", project_path(@project), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">Submissions</h1>
  </div>

  <% if @submissions.any? %>
    <ul class="divide-y divide-gray-200 border rounded-lg bg-white shadow-sm">
      <% @submissions.each do |submission| %>
        <li class="px-4 py-4">
          <%= link_to project_submission_path(@project, submission), class: "block hover:bg-gray-50 -mx-4 px-4 py-1 rounded" do %>
            <div class="flex items-center justify-between">
              <span class="font-medium text-gray-900"><%= submission.title %></span>
              <span class="text-xs font-medium px-2 py-1 rounded-full
                <%= submission.status == 'accepted' ? 'bg-blue-100 text-blue-800' :
                    submission.status == 'shipped'  ? 'bg-green-100 text-green-800' :
                    'bg-yellow-100 text-yellow-800' %>">
                <%= submission.status %>
              </span>
            </div>
            <div class="text-sm text-gray-500 mt-1">
              <%= submission.collaborator.name %> &middot; <%= submission.created_at.strftime("%b %-d, %Y") %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg font-medium">No submissions yet</p>
      <p class="text-sm mt-1">Share your project link to start receiving user stories.</p>
    </div>
  <% end %>
</div>
