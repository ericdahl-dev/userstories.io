<% content_for :title, "Submissions - #{@project.name}" %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-4xl px-6 py-10">
  <div class="mb-8">
    <%= link_to "← #{@project.name}", project_path(@project), class: "btn-ghost text-xs" %>
    <h1 class="mt-4 text-xl font-semibold text-stone-900 dark:text-stone-100">Submissions</h1>
    <p class="mt-0.5 font-mono text-sm text-stone-500"><%= @project.github_repo %></p>
  </div>

  <% if @submissions.any? %>
    <ul class="card-list">
      <% @submissions.each do |submission| %>
        <li>
          <%= link_to project_submission_path(@project, submission), class: "flex items-start justify-between gap-4 px-5 py-4 transition-colors duration-200 hover:bg-stone-50 dark:hover:bg-stone-800/60" do %>
            <div class="min-w-0">
              <p class="truncate text-sm font-medium text-stone-900 dark:text-stone-100"><%= submission.title %></p>
              <p class="mt-1 text-xs text-stone-500"><%= submission.collaborator.name %> &middot; <%= submission.created_at.strftime("%b %-d, %Y") %></p>
            </div>
            <%= render "shared/status_badge", status: submission.status %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">
      <p class="text-sm font-semibold text-stone-900 dark:text-stone-100">No submissions yet</p>
      <p class="mt-2 text-sm text-stone-500">Share your project portal link to start receiving user stories.</p>
    </div>
  <% end %>
</main>
