<header class="px-6 py-3.5 border-b border-gray-100 bg-white sticky top-0 z-10">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="text-sm font-semibold text-gray-900 tracking-tight">userstories.io</a>
      <nav class="hidden sm:flex items-center gap-1">
        <%= link_to "Inbox", dashboard_path,
              class: "px-3 py-1.5 text-sm rounded-md transition-colors #{request.path == dashboard_path ? 'bg-gray-100 text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50'}" %>
        <%= link_to "Projects", projects_path,
              class: "px-3 py-1.5 text-sm rounded-md transition-colors #{request.path.start_with?(projects_path) ? 'bg-gray-100 text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50'}" %>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden sm:block text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "text-sm text-gray-500 hover:text-gray-900 transition-colors" %>
    </div>
  </div>
</header>
