<header class="sticky top-0 z-10 border-b border-stone-200/80 bg-white/90 px-6 py-3.5 backdrop-blur-md dark:border-stone-800 dark:bg-stone-900/90">
  <div class="mx-auto flex max-w-6xl items-center justify-between">
    <div class="flex items-center gap-6">
      <%= render "shared/logo" %>
      <nav class="hidden items-center gap-1 sm:flex" aria-label="Developer">
        <%= link_to "Inbox", dashboard_path,
              class: request.path == dashboard_path ? "nav-link-active" : "nav-link-idle" %>
        <%= link_to "Projects", projects_path,
              class: request.path.start_with?(projects_path) ? "nav-link-active" : "nav-link-idle" %>
        <% if current_user.admin? %>
          <%= link_to "Ops", admin_root_path,
                class: request.path.start_with?("/admin") ? "nav-link-active" : "nav-link-idle" %>
        <% end %>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden text-sm text-stone-500 sm:block dark:text-stone-400"><%= current_user.email %></span>
      <%= render "shared/theme_toggle" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn-ghost" %>
    </div>
  </div>
</header>
