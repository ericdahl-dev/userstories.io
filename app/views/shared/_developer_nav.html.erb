<header class="px-6 py-3.5 border-b border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 sticky top-0 z-10">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-6">
      <%= render "shared/logo" %>
      <nav class="hidden sm:flex items-center gap-1">
        <%= link_to "Inbox", dashboard_path,
              class: "px-3 py-1.5 text-sm rounded-md transition-colors #{request.path == dashboard_path ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-medium' : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-800'}" %>
        <%= link_to "Projects", projects_path,
              class: "px-3 py-1.5 text-sm rounded-md transition-colors #{request.path.start_with?(projects_path) ? 'bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-medium' : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-800'}" %>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden sm:block text-sm text-gray-400 dark:text-gray-500"><%= current_user.email %></span>
      <%= render "shared/theme_toggle" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors" %>
    </div>
  </div>
</header>
