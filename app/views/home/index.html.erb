<% content_for :title, "userstories.io - Stakeholder feedback, structured and in GitHub" %>

<div class="min-h-[100dvh] bg-white flex flex-col">

  <%# Nav %>
  <header class="px-6 py-4 border-b border-gray-100">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/" class="text-sm font-semibold text-gray-900 tracking-tight">userstories.io</a>
      <%= button_to "Sign in with GitHub",
            user_github_omniauth_authorize_path,
            class: "inline-flex items-center gap-2 px-3.5 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors",
            data: { turbo: false } %>
    </div>
  </header>

  <%# Hero %>
  <section class="flex-1 flex items-center px-6 py-20">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center w-full">
      <div>
        <p class="text-xs font-medium tracking-widest text-indigo-500 uppercase mb-5">For developers on GitHub</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-950 leading-[1.1] mb-6">
          Stakeholder feedback,<br>structured and in GitHub.
        </h1>
        <p class="text-base text-gray-500 leading-relaxed max-w-sm mb-8">
          Share a link. Your collaborators submit stories in plain language. You triage them and a GitHub issue is created on acceptance.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-3">
          <%= button_to "Get started with GitHub",
                user_github_omniauth_authorize_path,
                class: "inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 active:scale-[0.98] transition-all",
                data: { turbo: false } %>
          <span class="text-sm text-gray-400 self-center">Free to use. No credit card.</span>
        </div>
      </div>

      <div class="hidden lg:block">
        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 space-y-3">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-4">Triage inbox</p>
          <% [
            { title: "Add dark mode to the dashboard", name: "Maya R.", project: "Horizon App", status: "pending" },
            { title: "Export submissions as CSV", name: "Tom B.", project: "Horizon App", status: "pending" },
            { title: "Show estimated delivery date on orders", name: "Priya K.", project: "Storefront", status: "accepted" },
          ].each_with_index do |item, i| %>
            <div class="bg-white border border-gray-200 rounded-xl px-4 py-3.5 flex items-start justify-between gap-3 <%= i == 0 ? 'ring-2 ring-indigo-500 ring-offset-1' : '' %>">
              <div class="min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= item[:title] %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= item[:name] %> &middot; <%= item[:project] %></p>
              </div>
              <% if item[:status] == "pending" %>
                <span class="shrink-0 text-[10px] font-medium bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded-full">pending</span>
              <% else %>
                <span class="shrink-0 text-[10px] font-medium bg-blue-50 text-blue-700 border border-blue-200 px-2 py-0.5 rounded-full">accepted</span>
              <% end %>
            </div>
          <% end %>
          <div class="pt-2 flex items-center gap-2">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500"></span>
            <p class="text-xs text-gray-400">2 pending &middot; 1 accepted this week</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# Steps %>
  <section class="border-t border-gray-900 px-6 py-16 bg-gray-950">
    <div class="max-w-6xl mx-auto">
      <div class="grid sm:grid-cols-3 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-gray-800">
        <div class="pb-8 sm:pb-0 sm:pr-12">
          <p class="text-xs font-mono text-gray-500 mb-3">01</p>
          <h3 class="text-sm font-semibold text-white mb-2">Connect your repo</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Sign in with GitHub and link a project to any repository you own.</p>
        </div>
        <div class="py-8 sm:py-0 sm:px-12">
          <p class="text-xs font-mono text-gray-500 mb-3">02</p>
          <h3 class="text-sm font-semibold text-white mb-2">Share a link</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Send your portal link to stakeholders. They sign in with their email, no GitHub account needed.</p>
        </div>
        <div class="pt-8 sm:pt-0 sm:pl-12">
          <p class="text-xs font-mono text-gray-500 mb-3">03</p>
          <h3 class="text-sm font-semibold text-white mb-2">Accept to ship</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Review submissions in your inbox. Accept what's actionable and a GitHub issue is created instantly.</p>
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-gray-950 border-t border-gray-800 px-6 py-6">
    <div class="max-w-6xl mx-auto flex items-center justify-between text-xs text-gray-600">
      <span>userstories.io</span>
      <span>&copy; <%= Date.today.year %></span>
    </div>
  </footer>

</div>
