<% content_for :title, "userstories.io - Stakeholder feedback, structured and in GitHub" %>
<% content_for :meta_description, "Collect user stories from collaborators via a shareable link. Triage in your inbox and open GitHub issues when you accept." %>

<div id="main-content" class="flex min-h-[100dvh] flex-col surface-page">

  <header class="border-b border-stone-200/80 bg-white/80 px-6 py-4 backdrop-blur-md dark:border-stone-800 dark:bg-stone-950/80">
    <div class="mx-auto flex max-w-6xl items-center justify-between">
      <%= render "shared/logo" %>
      <div class="flex items-center gap-3">
        <%= render "shared/theme_toggle" %>
        <% if user_signed_in? %>
          <%= link_to "Go to dashboard", dashboard_path, class: "btn-primary-sm" %>
        <% else %>
          <%= button_to "Sign in with GitHub",
                user_github_omniauth_authorize_path,
                class: "btn-github px-3.5 py-2",
                data: { turbo: false } %>
        <% end %>
      </div>
    </div>
  </header>

  <section class="flex flex-1 items-center px-6 py-16 sm:py-24">
    <div class="mx-auto grid w-full max-w-6xl items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-20">
      <div class="max-w-xl">
        <p class="mb-5 text-sm font-medium italic text-brand-700 dark:text-brand-400">For developers on GitHub</p>
        <h1 class="text-balance text-4xl font-bold leading-[1.08] tracking-[-0.03em] text-stone-950 sm:text-5xl lg:text-[3.25rem] dark:text-stone-50">
          Stakeholder feedback, structured and in GitHub.
        </h1>
        <p class="text-pretty mt-6 max-w-md text-base leading-relaxed text-stone-600 dark:text-stone-400">
          Share a link. Collaborators submit stories in plain language. You triage them, and a GitHub issue is created when you accept.
        </p>
        <div class="mt-9 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <%= button_to "Get started with GitHub",
                user_github_omniauth_authorize_path,
                class: "btn-primary px-5",
                data: { turbo: false } %>
          <span class="text-sm text-stone-500 dark:text-stone-500">Free to use. No credit card.</span>
        </div>
      </div>

      <div class="hidden lg:block">
        <div class="hero-preview rotate-1 space-y-3 lg:-rotate-1">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.12em] text-stone-500">Triage inbox</p>
          <% [
            { title: "Add dark mode to the dashboard", name: "Maya R.", project: "Horizon App", status: "pending" },
            { title: "Export submissions as CSV", name: "Tom B.", project: "Horizon App", status: "pending" },
            { title: "Show estimated delivery date on orders", name: "Priya K.", project: "Storefront", status: "accepted" },
          ].each_with_index do |item, i| %>
            <div class="surface-elevated flex items-start justify-between gap-3 rounded-xl border border-stone-200 px-4 py-3.5 dark:border-stone-800 <%= i == 0 ? 'ring-2 ring-brand-600/40 ring-offset-2 ring-offset-stone-100 dark:ring-offset-stone-900' : '' %>">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-stone-900 dark:text-stone-100"><%= item[:title] %></p>
                <p class="mt-0.5 text-xs text-stone-500"><%= item[:name] %> &middot; <%= item[:project] %></p>
              </div>
              <%= render "shared/status_badge", status: item[:status] %>
            </div>
          <% end %>
          <div class="flex items-center gap-2 pt-2">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <p class="tabular-nums text-xs text-stone-500">2 pending &middot; 1 accepted this week</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200 bg-stone-100/60 px-6 py-20 dark:border-stone-800 dark:bg-stone-900/40">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 max-w-lg">
        <h2 class="text-balance text-2xl font-semibold tracking-tight text-stone-900 dark:text-stone-100">How it works</h2>
        <p class="text-pretty mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400">Three steps from repo to structured feedback in your workflow.</p>
      </div>

      <ol class="grid gap-10 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
        <% [
          { step: "01", title: "Connect your repo", body: "Sign in with GitHub and link a project to any repository you own." },
          { step: "02", title: "Share a link", body: "Send your portal link to stakeholders. They sign in with email — no GitHub account needed." },
          { step: "03", title: "Accept to ship", body: "Review submissions in your inbox. Accept what's actionable and a GitHub issue is created instantly." },
        ].each do |item| %>
          <li class="group">
            <p class="mb-3 font-mono text-xs tabular-nums text-brand-700 dark:text-brand-400"><%= item[:step] %></p>
            <h3 class="mb-2 text-base font-semibold text-stone-900 dark:text-stone-100"><%= item[:title] %></h3>
            <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-400"><%= item[:body] %></p>
          </li>
        <% end %>
      </ol>
    </div>
  </section>

  <footer class="border-t border-stone-200 px-6 py-8 dark:border-stone-800">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 text-xs text-stone-500 sm:flex-row sm:items-center sm:justify-between">
      <%= render "shared/logo", text_class: "text-xs text-stone-500", icon_class: "w-5 h-5" %>
      <div class="flex items-center gap-4">
        <span>&copy; <%= Date.today.year %> userstories.io</span>
      </div>
    </div>
  </footer>

</div>
