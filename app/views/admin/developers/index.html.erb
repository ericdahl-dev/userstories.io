<% content_for :title, "Developers" %>

<%= render "shared/developer_nav" %>

<main id="main-content" class="mx-auto max-w-6xl px-6 py-10">
  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm text-stone-500">
        <%= link_to "Ops dashboard", admin_root_path, class: "text-sm text-stone-500 hover:text-stone-700 dark:hover:text-stone-300" %>
      </p>
      <h1 class="mt-1 text-xl font-semibold text-stone-900 dark:text-stone-100">Developers</h1>
      <p class="mt-0.5 text-sm text-stone-500">Search registered developers and grant refinement credits.</p>
    </div>
  </div>

  <%= form_with url: admin_developers_path, method: :get, class: "mb-6 flex flex-wrap gap-3" do %>
    <%= text_field_tag :q, @query, placeholder: "Search by email", class: "input-field max-w-md" %>
    <%= submit_tag "Search", class: "btn-secondary" %>
  <% end %>

  <div class="card overflow-hidden">
    <table class="min-w-full divide-y divide-stone-200 dark:divide-stone-800">
      <thead class="bg-stone-50 dark:bg-stone-900/50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-stone-500">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-stone-500">Plan</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-stone-500">Usage</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-stone-500">Credits</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200 dark:divide-stone-800">
        <% @developers.each do |developer| %>
          <tr>
            <td class="px-4 py-3 text-sm text-stone-900 dark:text-stone-100"><%= developer.email %></td>
            <td class="px-4 py-3 text-sm capitalize text-stone-600 dark:text-stone-400"><%= developer.plan %></td>
            <td class="px-4 py-3 text-sm text-stone-600 dark:text-stone-400">
              <%= developer.refinement_usage_count %> / <%= developer.refinement_quota %>
            </td>
            <td class="px-4 py-3 text-sm text-stone-600 dark:text-stone-400"><%= developer.refinement_credit_balance %></td>
            <td class="px-4 py-3 text-right text-sm">
              <%= link_to "Manage", admin_developer_path(developer), class: "text-sm font-medium text-stone-700 hover:text-stone-900 dark:text-stone-300 dark:hover:text-stone-100" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</main>
