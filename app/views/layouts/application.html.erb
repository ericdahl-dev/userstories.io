<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "userstories.io" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Share a link for stakeholder feedback. Triage submissions and create GitHub issues when you accept." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="userstories.io">
    <meta name="mobile-web-app-capable" content="yes">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="userstories.io">
    <meta property="og:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || "userstories.io" %>">
    <meta property="og:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || "Share a link for stakeholder feedback. Triage submissions and create GitHub issues when you accept." %>">
    <meta property="og:url" content="<%= content_for(:og_url).presence || request.url %>">
    <meta property="og:image" content="<%= content_for(:og_image).presence || asset_url("apple-touch-icon.png") %>">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || "userstories.io" %>">
    <meta name="twitter:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || "Share a link for stakeholder feedback. Triage submissions and create GitHub issues when you accept." %>">
    <meta name="twitter:image" content="<%= content_for(:og_image).presence || asset_url("apple-touch-icon.png") %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
    <link rel="manifest" href="<%= pwa_manifest_path %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="grain-overlay h-full surface-page antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <% if notice.present? %>
      <div class="flash-notice" role="status"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="flash-alert" role="alert"><%= alert %></div>
    <% end %>

    <%= yield %>

    <script>
      (function() {
        function updateToggle(btn) {
          var isDark = document.documentElement.classList.contains("dark");
          var iconDark = btn.querySelector('[data-theme-icon="dark"]');
          var iconLight = btn.querySelector('[data-theme-icon="light"]');
          iconDark.classList.toggle("hidden", !isDark);
          iconLight.classList.toggle("hidden", isDark);
          btn.setAttribute("aria-pressed", isDark ? "true" : "false");
          btn.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
        }

        function initToggles() {
          document.querySelectorAll("[data-theme-toggle]").forEach(updateToggle);
        }

        document.addEventListener("click", function(event) {
          var btn = event.target.closest("[data-theme-toggle]");
          if (!btn) return;

          var nowDark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("theme", nowDark ? "dark" : "light");
          document.querySelectorAll("[data-theme-toggle]").forEach(updateToggle);
        });

        initToggles();
        document.addEventListener("turbo:load", initToggles);
      })();
    </script>
  </body>
</html>
